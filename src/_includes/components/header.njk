<header
  id="main-header"
  class="fixed inset-x-0 top-0 z-50 py-6 px-8 md:px-16 transition-all duration-300 border-b border-transparent bg-transparent"
>
  <div class="max-w-full mx-auto flex items-center justify-between">
    <a
      href="/"
      class="group font-serif text-5xl text-relatio-off tracking-wide hover:text-relatio-accent transition-colors relative z-50"
      aria-label="Página inicial Relatio"
    >
      Relatio<span class="text-relatio-accent transition-all duration-300 group-hover:text-relatio-blue">.</span>
    </a>
    {% if not hideMenu %}
      <button
        id="menu-btn"
        data-open="false"
        class="group w-10 h-6 flex flex-col justify-between items-end relative z-50 focus:outline-none cursor-pointer"
        aria-label="Alternar menu"
        aria-expanded="false"
      >
        <span class="h-0.5 bg-relatio-off transition-all duration-300 w-1/3 group-hover:w-full group-hover:bg-relatio-accent group-data-[open=true]:w-full group-data-[open=true]:bg-relatio-blue group-data-[open=true]:rotate-45 group-data-[open=true]:translate-y-2.75"></span>
        <span class="h-0.5 bg-relatio-off transition-all duration-300 w-1/2 group-hover:w-full group-hover:bg-relatio-accent group-data-[open=true]:opacity-0 group-data-[open=true]:-translate-x-4"></span>
        <span class="h-0.5 bg-relatio-off transition-all duration-300 w-[calc(50%+15px)] group-hover:w-full group-hover:bg-relatio-accent group-data-[open=true]:w-full group-data-[open=true]:bg-relatio-blue group-data-[open=true]:-rotate-45 group-data-[open=true]:-translate-y-2.75"></span>
      </button>
    {% endif %}
  </div>
</header>

<nav
  id="mobile-menu"
  class="fixed inset-0  backdrop-blur-xl flex flex-col items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300 z-40"
>
  <ul class="flex flex-col items-center gap-8 text-center">
    <li>
      <a href="#quem" class="menu-link font-serif text-4xl md:text-6xl text-relatio-off hover:text-relatio-accent transition-colors">Para quem</a>
    </li>
    <li>
      <a href="#processo" class="menu-link font-serif text-4xl md:text-6xl text-relatio-off hover:text-relatio-accent transition-colors">Processo</a>
    </li>
    <li>
      <a href="#servicos" class="menu-link font-serif text-4xl md:text-6xl text-relatio-off hover:text-relatio-accent transition-colors">Serviços</a>
    </li>
    <li>
      <a href="#resultados" class="menu-link font-serif text-4xl md:text-6xl text-relatio-off hover:text-relatio-accent transition-colors">Resultados</a>
    </li>
  </ul>

  <a
    href="https://wa.me/5511999999999"
    target="_blank"
    class="mt-14 text-sm tracking-[0.2em] uppercase py-4 px-8 bg-relatio-accent text-relatio-off font-medium hover:bg-relatio-blue transition-all duration-500 ease-in-out hover:shadow-xl"
  >
    Diagnóstico grátis
  </a>
</nav>